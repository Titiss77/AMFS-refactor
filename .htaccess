# Bloquer l'accès aux fichiers de configuration
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Optionnel : Bloquer l'accès aux fichiers SQL
<FilesMatch "\.sql$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>